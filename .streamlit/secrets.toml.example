# Copy this file to .streamlit/secrets.toml (git-ignored) and fill in real values.
# On Streamlit Community Cloud, paste these same keys into the app's "Secrets" box instead.

# Base URL of the deployed Modal backend (no trailing slash).
MODAL_ENDPOINT_URL = "https://<your-workspace>--chatbot-backend-fastapi-app.modal.run"

# Shared bearer token — must match CHATBOT_API_TOKEN in the Modal "chatbot-secrets" secret.
CHATBOT_API_TOKEN = "your-token-here"
