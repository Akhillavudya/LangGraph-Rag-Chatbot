GROQ_API_KEY=your_groq_api_key_here
# HF token is now optional: it's only used to download the local MiniLM embedding model, not for the LLM.
HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here
ALPHAVANTAGE_API_KEY=your_alphavantage_key_here
QDRANT_URL=https://your-cluster-url.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

NEON_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=Chatbot Project
